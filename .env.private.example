# GoldBank Server v3.0 — variáveis de ambiente
# Copie para .env.private e preencha os valores
# Em produção: use Google Secret Manager (não este arquivo)

# ─── ASAAS (conta mestre — usada apenas para criar subcontas) ─────────────────
# A conta mestre é a sua conta Asaas principal (conta White Label).
# Cada usuário cadastrado ganha uma SUBCONTA própria (POST /accounts),
# com walletId, saldo e chave PIX individuais.
ASAAS_API_KEY=$aact_prod_SUA_CHAVE_MESTRE_AQUI
ASAAS_BASE_URL=https://api.asaas.com/v3
# Sandbox para testes: https://sandbox.asaas.com/api/v3

# ─── SEGURANÇA ────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=chave_hex_64_chars_aqui

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=chave_jwt_128_chars_aqui

# ─── GTK INTEGRATION ─────────────────────────────────────────────────────────
GTK_API_URL=https://api.gtk.bank
GTK_API_KEY=gtk_api_key_prod_2026_a1b2c3d4e5

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dev: http://localhost:8081,exp://localhost:8081
# Prod: https://app.gtk.bank,https://goldbank.app
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# ─── BANCO DE DADOS (PostgreSQL) ─────────────────────────────────────────────
# Render: cole aqui a "Internal Database URL" do seu PostgreSQL
# Dev local: postgresql://postgres:senha@localhost:5432/goldbank
DATABASE_URL=postgresql://usuario:senha@host:5432/goldbank

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=8082
NODE_ENV=development
